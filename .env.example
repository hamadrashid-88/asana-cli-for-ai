# Asana CLI Configuration
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Your Personal Access Token (required)
# Generate one at: https://app.asana.com/0/developer-console → Personal access tokens
ASANA_ACCESS_TOKEN=

# Your Workspace GID (required)
# Run: node asana-cli.js workspaces (after setting your token) to find it
ASANA_WORKSPACE_GID=
